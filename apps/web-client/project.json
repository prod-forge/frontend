{
  "name": "web-client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/web-client/src",
  "tags": ["scope:app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run build",
        "cwd": "apps/web-client"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run dev",
        "cwd": "apps/web-client"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run format",
        "cwd": "apps/web-client"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint",
        "cwd": "apps/web-client"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run test",
        "cwd": "apps/web-client"
      }
    },
    "test:cov": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run test:cov",
        "cwd": "apps/web-client"
      }
    },
    "test:watch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run test:watch",
        "cwd": "apps/web-client"
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run e2e",
        "cwd": "apps/web-client"
      }
    },
    "test:e2e:cov": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run test:e2e:cov",
        "cwd": "apps/web-client"
      }
    }
  }
}
