{
  "name": "todolist-ai",
  "version": "1.0.0",
  "description": "An experiment in creating a project from scratch using Claude Code",
  "homepage": "https://github.com/AlexSergey/todolist-ai#readme",
  "bugs": {
    "url": "https://github.com/AlexSergey/todolist-ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexSergey/todolist-ai.git"
  },
  "license": "MIT",
  "author": "Aleksandrov Sergey <gooddev.sergey@gmail.com>",
  "scripts": {
    "build": "tsc -b && vite build",
    "build:analyze": "tsc -b && ANALYZE=true vite build",
    "build:storybook": "storybook build",
    "doctor": "react-doctor .",
    "format": "npm run format:prettier && npm run format:code",
    "format:code": "eslint . --fix",
    "format:prettier": "prettier --write \"src/**/*.{ts,json}\"",
    "full-check": "npm run lint && npm run knip && npm run test && npm run test:e2e && npm run test:visual && npm run test:a11y",
    "knip": "knip",
    "lint": "npm run lint:ts && npm run lint:code",
    "lint:code": "eslint .",
    "lint:commit": "commitlint --config .commitlintrc.cjs --edit",
    "lint:ts": "tsc --noEmit",
    "pre-commit": "lint-staged --config .lintstagedrc.cjs",
    "prepare": "husky",
    "preview": "vite preview",
    "start": "vite",
    "storybook": "storybook dev -p 6006",
    "test": "vitest run --project unit",
    "test:a11y": "playwright test --config=playwright.a11y.config.ts",
    "test:cov": "vitest run --project unit --coverage",
    "test:e2e": "playwright test",
    "test:e2e:cov": "rm -rf .nyc_output && playwright test --config=playwright.coverage.config.ts && nyc report && nyc check-coverage",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "test:visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "test:watch": "vitest --project unit"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@reduxjs/toolkit": "2.11.2",
    "@sentry/react": "10.53.1",
    "classnames": "2.5.1",
    "logrock": "5.2.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.75.0",
    "react-redux": "9.2.0",
    "react-router-dom": "7.15.0",
    "redux": "5.0.1",
    "uuid": "14.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@chromatic-com/storybook": "5.2.1",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@eslint-react/eslint-plugin": "5.7.8",
    "@eslint/js": "10.0.1",
    "@eslint/json": "1.2.0",
    "@playwright/test": "1.60.0",
    "@sentry/vite-plugin": "5.3.0",
    "@storybook/addon-a11y": "10.4.0",
    "@storybook/addon-docs": "10.4.0",
    "@storybook/addon-vitest": "10.4.0",
    "@storybook/react-vite": "10.4.0",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser-playwright": "4.1.6",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-check-file": "3.3.1",
    "eslint-plugin-import-lite": "0.6.0",
    "eslint-plugin-no-only-tests": "3.4.0",
    "eslint-plugin-package-json": "0.91.2",
    "eslint-plugin-perfectionist": "5.9.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-storybook": "10.4.0",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "knip": "6.13.1",
    "lint-staged": "17.0.4",
    "nyc": "18.0.0",
    "playwright": "1.60.0",
    "prettier": "3.8.3",
    "react-doctor": "0.1.6",
    "rollup-plugin-visualizer": "7.0.1",
    "storybook": "10.4.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.13",
    "vite-plugin-istanbul": "8.0.0",
    "vitest": "4.1.6"
  }
}
