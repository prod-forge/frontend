{
  "name": "prod-forge-todolist-frontend",
  "version": "1.0.0",
  "description": "An experiment in creating a project from scratch using Claude Code",
  "homepage": "https://github.com/AlexSergey/todolist-ai#readme",
  "bugs": {
    "url": "https://github.com/AlexSergey/todolist-ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexSergey/todolist-ai.git"
  },
  "license": "MIT",
  "author": "Aleksandrov Sergey <gooddev.sergey@gmail.com>",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "build:web-client": "nx build web-client",
    "design-token:build": "nx run design-tokens:build",
    "dev": "nx serve web-client",
    "doctor": "react-doctor .",
    "format": "nx run-many -t format",
    "full-check": "npm run lint && npm run knip && npm run test && npm run test:e2e && npm run test:visual && npm run test:a11y",
    "knip": "knip",
    "lint": "nx run-many -t lint --output-style=stream",
    "lint:commit": "commitlint --config .commitlintrc.cjs --edit",
    "pre-commit": "lint-staged --config .lintstagedrc.cjs",
    "prepare": "husky",
    "release": "tsx release/before-release.ts && npx release-it",
    "storybook": "nx storybook ui-web",
    "storybook:build": "nx build-storybook ui-web",
    "test": "nx run-many -t test",
    "test:a11y": "nx test:a11y ui-web",
    "test:cov": "nx run-many -t test:cov",
    "test:e2e": "nx test:e2e web-client",
    "test:e2e:cov": "nx test:e2e:cov web-client",
    "test:visual": "nx test:visual ui-web",
    "test:visual:update": "nx test:visual:update ui-web"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@eslint-react/eslint-plugin": "5.7.8",
    "@eslint/js": "10.0.1",
    "@eslint/json": "1.2.0",
    "@inquirer/checkbox": "5.1.5",
    "@inquirer/prompts": "8.4.3",
    "@playwright/test": "1.60.0",
    "@release-it/conventional-changelog": "11.0.0",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser-playwright": "4.1.6",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-check-file": "3.3.1",
    "eslint-plugin-import-lite": "0.6.0",
    "eslint-plugin-no-only-tests": "3.4.0",
    "eslint-plugin-package-json": "0.91.2",
    "eslint-plugin-perfectionist": "5.9.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-storybook": "10.4.0",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "knip": "6.13.1",
    "lint-staged": "17.0.4",
    "nx": "22.7.2",
    "nyc": "18.0.0",
    "playwright": "1.60.0",
    "prettier": "3.8.3",
    "react-doctor": "0.1.6",
    "release-it": "20.0.1",
    "stylelint": "16.13.2",
    "stylelint-config-standard": "36.0.1",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.13",
    "vite-plugin-istanbul": "8.0.0",
    "vitest": "4.1.6"
  }
}
