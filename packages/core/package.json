{
  "name": "@prod-forge-todolist-frontend/core",
  "version": "1.0.0",
  "description": "Business logic, Redux store, API layer, and services for prod-forge-todolist-frontend",
  "license": "MIT",
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "format": "npm run format:prettier && npm run format:code",
    "format:code": "eslint . --fix",
    "format:prettier": "prettier --write \"src/**/*.{ts,json}\"",
    "lint": "npm run lint:ts && npm run lint:code",
    "lint:code": "eslint .",
    "lint:commit": "commitlint --config .commitlintrc.cjs --edit",
    "lint:ts": "tsc --noEmit"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@reduxjs/toolkit": "2.11.2",
    "@sentry/react": "10.53.1",
    "logrock": "5.2.0",
    "uuid": "14.0.0",
    "zod": "4.4.3"
  }
}
